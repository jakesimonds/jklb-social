# Playwright Test Credentials
# Copy this file to .env.test and fill in your values
# .env.test is gitignored - NEVER commit real credentials

# Bluesky test account (use an app password, not your real password)
# Create app password at: https://bsky.app/settings/app-passwords
TEST_HANDLE=your-test-account.bsky.social
TEST_PASSWORD=xxxx-xxxx-xxxx-xxxx
